---
import HeroIcons from "./HeroIcons.astro";
import HeroTipCard from "./HeroTipCard.astro";
import type { HeroTip } from "@/lib/hero-tip-card";
import HeroContent from "./HeroContent.astro";

interface Props {
  totalTips: number;
  totalContribs: number;
  totalStacks: number;
  heroTips: HeroTip[];
  stackNames: string[];
}

const { totalTips, totalContribs, totalStacks, heroTips, stackNames } = Astro.props;
---

<section
  id="hero"
  style="
    background: #0c1220;
    min-height: 100svh;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  "
>
  <!-- Mesh aurora blobs -->
  <div aria-hidden="true" style="position:absolute; inset:0; overflow:hidden; pointer-events:none;">
    <div class="mesh-blob-dark mesh-blob-dark-cream"></div>
    <div class="mesh-blob-dark mesh-blob-dark-magenta"></div>
    <div class="mesh-blob-dark mesh-blob-dark-lavender"></div>
    <div class="mesh-blob-dark mesh-blob-dark-indigo"></div>
    <div class="mesh-blob-dark mesh-blob-dark-ruby"></div>
  </div>

  <!-- Subtle grid overlay for depth -->
  <div
    aria-hidden="true"
    style="
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 30%, black 30%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 30%, black 30%, transparent 100%);
    "
  >
  </div>

  <HeroIcons />
  <HeroTipCard tips={heroTips} />
  <HeroContent
    totalTips={totalTips}
    totalContribs={totalContribs}
    totalStacks={totalStacks}
    stackNames={stackNames}
  />

  <!-- Bottom fade to white -->
  <div
    aria-hidden="true"
    style="
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 160px;
      background: linear-gradient(to bottom, transparent, #ffffff);
      pointer-events: none;
      z-index: 3;
    "
  >
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    /* ── Hero entrance — fromTo eliminates the opacity-0 CSS bug ── */
    gsap
      .timeline({ defaults: { ease: "power3.out" } })
      .fromTo(
        "[data-hero='eyebrow']",
        { opacity: 0, y: 18 },
        { opacity: 1, y: 0, duration: 0.65 },
        0.15
      )
      .fromTo(
        "[data-hero='title']",
        { opacity: 0, y: 40 },
        { opacity: 1, y: 0, duration: 0.85 },
        0.3
      )
      .fromTo("[data-hero='sub']", { opacity: 0, y: 22 }, { opacity: 1, y: 0, duration: 0.7 }, 0.55)
      .fromTo("[data-hero='body']", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, 0.7)
      .fromTo("[data-hero='cta']", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, 0.85)
      .fromTo(
        "[data-hero='trust']",
        { opacity: 0, y: 12 },
        { opacity: 1, y: 0, duration: 0.55 },
        0.95
      )
      .fromTo(
        "[data-hero='stats']",
        { opacity: 0, y: 12 },
        { opacity: 1, y: 0, duration: 0.55 },
        1.05
      );

    /* ── Stat counter animation ─────────────────────────────── */
    document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
      const target = parseInt(el.dataset.count ?? "0", 10);
      if (!target) return;
      ScrollTrigger.create({
        trigger: el,
        start: "top 80%",
        once: true,
        onEnter() {
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 1.8,
            ease: "power2.out",
            onUpdate() {
              el.textContent = Math.round(obj.val).toString();
            },
          });
        },
      });
    });
  });
</script>
