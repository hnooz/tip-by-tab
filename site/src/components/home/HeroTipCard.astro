---
// Hero tip preview card — xl only, cycles through real tips from the collection.
import { accentStyle, buildHeroCards, type HeroTip } from "@/lib/hero-tip-card";

interface Props {
  tips: HeroTip[];
}

const { tips } = Astro.props;
const cards = await buildHeroCards(tips);
const firstCard = cards[0];
---

{
  firstCard && (
    <div
      id="hero-tip-card"
      class="hidden xl:block absolute"
      style="right:3%;top:50%;transform:translateY(-50%);z-index:3;width:248px;user-select:none;"
    >
      <div id="hc-inner">
        <div style="background:rgba(18,24,42,0.97);border:1px solid rgba(255,255,255,0.14);border-radius:16px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.6),0 0 0 1px rgba(255,255,255,0.06) inset;">
          <div style="padding:14px 16px 12px;border-bottom:1px solid rgba(255,255,255,0.08);">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
              <span
                id="hc-badge"
                style={`font-family:var(--font-mono);font-size:9px;font-weight:700;border-radius:9999px;padding:2px 9px;letter-spacing:0.12em;text-transform:uppercase;${accentStyle(0)}`}
              >
                {firstCard.label}
              </span>
              <span style="font-family:var(--font-mono);font-size:9px;color:rgba(255,255,255,0.45);letter-spacing:0.06em;">
                new tab
              </span>
            </div>
            <p
              id="hc-title"
              style="font-size:12px;font-weight:700;color:#ffffff;margin:0;line-height:1.35;letter-spacing:-0.01em;"
            >
              {firstCard.title}
            </p>
          </div>
          <div
            id="hc-code"
            class="hc-code"
            style="background:#060b14;padding:12px 14px;border-bottom:1px solid rgba(255,255,255,0.06);overflow:hidden;"
            set:html={firstCard.codeHtml}
          />
          <div style="background:rgba(255,255,255,0.04);padding:10px 14px;display:flex;align-items:center;gap:8px;">
            <img
              id="hc-avatar"
              src={`https://github.com/${firstCard.github}.png?size=44`}
              alt=""
              width="22"
              height="22"
              loading="lazy"
              style="width:22px;height:22px;border-radius:50%;flex-shrink:0;background:rgba(255,255,255,0.1);"
            />
            <span
              id="hc-author"
              style="font-family:var(--font-mono);font-size:10px;font-weight:600;color:rgba(255,255,255,0.65);"
            >
              @{firstCard.github}
            </span>
          </div>
        </div>
      </div>
      <script type="application/json" id="hc-data" set:html={JSON.stringify(cards)} />
    </div>
  )
}

<style>
  .hc-code :global(pre) {
    margin: 0;
    background: transparent !important;
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.7;
    white-space: pre;
  }
  .hc-code :global(code) {
    background: transparent !important;
  }
</style>

<script>
  import { initHeroTipCard } from "@/lib/hero-tip-card-client";

  initHeroTipCard();
</script>
