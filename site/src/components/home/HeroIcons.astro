---
// Floating stack icons — decorative, hidden progressively on smaller screens.
import { HERO_ICONS } from "@/lib/hero-icons-data";
import { HERO_ICONS_WIDE } from "@/lib/hero-icons-data-wide";

const icons = [...HERO_ICONS, ...HERO_ICONS_WIDE];

const HIDDEN_CLASS = { sm: "hidden sm:block", md: "hidden md:block", lg: "hidden lg:block" };
---

<div
  aria-hidden="true"
  class="absolute inset-0 overflow-hidden pointer-events-none max-w-xs md:max-w-5xl mx-auto"
  style="z-index:2;"
>
  {
    icons.map((icon) => (
      <div
        class:list={[
          "stack-icon absolute opacity-75 hover:opacity-100 transition-opacity duration-500 cursor-default",
          icon.hidden && HIDDEN_CLASS[icon.hidden],
        ]}
        style={`left:${icon.left};top:${icon.top};transform:translate(-50%,-50%);`}
        data-float={icon.float}
      >
        <div style={`width:${icon.size}px;height:${icon.size}px;`}>
          <Fragment set:html={icon.svg} />
        </div>
      </div>
    ))
  }
</div>

<script>
  import gsap from "gsap";

  if (window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
    document.querySelectorAll<HTMLElement>(".stack-icon").forEach((el, i) => {
      const floatY = parseFloat(el.dataset.float ?? "16");
      const seed = i * 2.618 + 0.5;
      const durY = 2.4 + (seed % 2.1);
      const durX = durY * (1.25 + ((i * 7) % 5) * 0.09);
      const delayY = (seed * 0.61) % 2.8;
      const delayX = (seed * 0.79 + 1.1) % 2.8;
      const floatX = (((i * 5 + 2) % 9) - 4) * 5;
      gsap.to(el, {
        y: -floatY,
        duration: durY,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: delayY,
      });
      gsap.to(el, {
        x: floatX,
        duration: durX,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: delayX,
      });
    });
</script>
