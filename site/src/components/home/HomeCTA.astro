---
// Dark CTA band — mirrors hero styling.
import { WEBSTORE_URL } from "@/lib/seo";
---

<section class="py-16 md:py-[100px] relative overflow-hidden" style="background: #0c1220;">
  <!-- Subtle mesh on dark CTA -->
  <div aria-hidden="true" style="position:absolute; inset:0; pointer-events:none; overflow:hidden;">
    <div
      style="
        position: absolute;
        width: 500px; height: 500px;
        background: rgba(83,58,253,0.2);
        border-radius: 50%;
        filter: blur(100px);
        top: -150px; right: -100px;
      "
    >
    </div>
    <div
      style="
        position: absolute;
        width: 400px; height: 400px;
        background: rgba(249,107,238,0.12);
        border-radius: 50%;
        filter: blur(80px);
        bottom: -100px; left: -80px;
      "
    >
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 relative" style="z-index:1;">
    <div class="max-w-[600px]" data-reveal>
      <h2
        class="font-serif text-[clamp(36px,5vw,56px)] font-semibold leading-[1.04] tracking-[-0.035em] text-white mb-[18px]"
      >
        One tip per tab.<br />
        <em class="gradient-text" style="font-style: italic;">Your name, permanently.</em>
      </h2>
      <p
        class="text-[16px] font-semibold leading-[1.65] mb-9 max-w-[440px]"
        style="color: rgba(255,255,255,0.55);"
      >
        Install the extension. Every new tab, one atomic tip from a real developer. When you
        contribute, your name lives there too.
      </p>
      <div class="flex flex-wrap items-center gap-3 sm:gap-[14px]">
        <a
          href={WEBSTORE_URL}
          data-install-cta
          target="_blank"
          rel="noopener noreferrer"
          style="
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            color: #0c1220;
            font-size: 15px;
            font-weight: 600;
            padding: 13px 28px;
            border-radius: 9999px;
            text-decoration: none;
            transition: opacity 0.15s;
          "
          onmouseenter="this.style.opacity='0.88'"
          onmouseleave="this.style.opacity='1'"
        >
          Install for Chrome — free
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <a
          href="/contribute"
          style="
            display: inline-flex;
            align-items: center;
            color: rgba(255,255,255,0.5);
            font-size: 15px;
            font-weight: 600;
            padding: 13px 16px;
            text-decoration: none;
            border-radius: 9999px;
            border: 1px solid rgba(255,255,255,0.12);
            transition: all 0.2s;
          "
          onmouseenter="this.style.color='rgba(255,255,255,0.85)';this.style.borderColor='rgba(255,255,255,0.3)'"
          onmouseleave="this.style.color='rgba(255,255,255,0.5)';this.style.borderColor='rgba(255,255,255,0.12)'"
        >
          Contribute a tip →
        </a>
      </div>
    </div>
  </div>
</section>
