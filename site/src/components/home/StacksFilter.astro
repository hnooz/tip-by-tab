---
import { stackLabel } from "@/lib/stacks";

interface Props {
  totalCount: number;
  stackCounts: [string, number][];
  allStackNames: string[];
}

const { totalCount, stackCounts, allStackNames } = Astro.props;
---

<!-- Search + filter row -->
<div class="flex flex-wrap gap-[10px] items-center">
  <!-- Stack search input -->
  <div class="relative flex-1 min-w-[180px] max-w-[320px]">
    <svg
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
      class="absolute left-[11px] top-1/2 -translate-y-1/2 text-ink-mute pointer-events-none"
    >
      <circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path>
    </svg>
    <input
      id="stack-search"
      type="search"
      placeholder={`Stack… (${allStackNames.slice(0, 3).join(", ")}…)`}
      autocomplete="off"
      spellcheck="false"
      style="width:100%;padding:8px 12px 8px 34px;border-radius:9999px;border:1px solid var(--color-hairline);background:var(--color-canvas);color:var(--color-ink);font-size:13px;font-weight:600;font-family:var(--font-sans);box-shadow:var(--shadow-1);outline:none;transition:border-color 0.15s, box-shadow 0.15s;"
      onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(83,58,253,0.12)';"
      onblur="this.style.borderColor='var(--color-hairline)'; this.style.boxShadow='var(--shadow-1)';"
    />
  </div>

  <!-- Stack filter pills -->
  <div id="filter-bar" class="flex flex-wrap gap-[6px] items-center">
    <button
      data-filter="all"
      class="filter-pill active"
      style="--pill-color: var(--color-primary);"
      aria-pressed="true"
    >
      All
      <span class="font-mono text-[10px] opacity-65 ml-1">{totalCount}</span>
    </button>
    {
      stackCounts.map(([stack, count]) => (
        <button
          data-filter={stack}
          class="filter-pill"
          style="--pill-color: var(--color-primary);"
          aria-pressed="false"
        >
          {stackLabel(stack)}
          <span class="font-mono text-[10px] opacity-65 ml-1">{count}</span>
        </button>
      ))
    }
  </div>
</div>

<script>
  import "@/lib/stacks-filter-client";
</script>
