---
// Centered hero copy: eyebrow, title, subtitle, body, CTAs, stats strip.
import { WEBSTORE_URL } from "@/lib/seo";

interface Props {
  totalTips: number;
  totalContribs: number;
  totalStacks: number;
  stackNames: string[];
}

const { totalTips, totalContribs, totalStacks, stackNames } = Astro.props;
const firstStack = stackNames[0] ?? "Laravel";
---

<div
  class="max-w-[1200px] mx-auto px-6 py-24 w-full relative flex flex-col items-center"
  style="z-index:3;"
>
  <div class="max-w-[680px] w-full text-center">
    <span
      data-hero="eyebrow"
      style="display:inline-flex;align-items:center;gap:6px;background:rgba(185,185,249,0.12);border:1px solid rgba(185,185,249,0.25);color:#b9b9f9;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px;border-radius:9999px;margin-bottom:24px;white-space:nowrap;"
    >
      <span
        style="width:5px;height:5px;border-radius:50%;background:#b9b9f9;display:inline-block;opacity:0.8;"
      ></span>
      Community-curated<span class="hidden sm:inline">· Contributor-credited</span>
    </span>

    <h1
      data-hero="title"
      style="font-family:var(--font-serif);font-size:clamp(52px, 7.5vw, 92px);font-weight:600;line-height:0.96;letter-spacing:-0.035em;color:#ffffff;margin:0 0 20px;"
    >
      One<br />
      <em style="font-style: italic; color: rgba(255,255,255,0.65);">atomic</em><br />
      tip per tab.
    </h1>

    <p
      data-hero="sub"
      style="font-family:var(--font-serif);font-size:clamp(18px, 2.2vw, 26px);font-weight:600;font-style:italic;line-height:1.3;color:#b9b9f9;margin:0 auto 20px;max-width:480px;"
    >
      Your name on every reader's new tab.
    </p>

    <p
      data-hero="body"
      style="font-size:16px;font-weight:600;line-height:1.65;color:rgba(255,255,255,0.72);max-width:400px;margin:0 auto 36px;"
    >
      A free browser extension for <span
        id="stack-cycle"
        class="min-w-16"
        style="color:#b9b9f9;display:inline-block;transition:opacity 0.28s ease,transform 0.28s ease;"
        >{firstStack}</span
      > engineers. Every new tab shows one tip. Learn one thing, ship better code.
    </p>
    <script type="application/json" id="stack-cycle-data" set:html={JSON.stringify(stackNames)} />

    <div data-hero="cta" class="flex flex-wrap items-center justify-center gap-3">
      <a
        href={WEBSTORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;background:#ffffff;color:#0c1220;font-size:15px;font-weight:600;padding:13px 28px;border-radius:9999px;text-decoration:none;transition:opacity 0.15s;white-space:nowrap;"
      >
        Install for Chrome — free
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
        >
      </a>
      <a
        href="/contribute"
        style="display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,0.72);font-size:15px;font-weight:600;padding:13px 16px;text-decoration:none;border-radius:9999px;border:1px solid rgba(255,255,255,0.14);transition:color 0.2s, border-color 0.2s;white-space:nowrap;"
        onmouseenter="this.style.color='rgba(255,255,255,0.95)';this.style.borderColor='rgba(255,255,255,0.3)'"
        onmouseleave="this.style.color='rgba(255,255,255,0.72)';this.style.borderColor='rgba(255,255,255,0.14)'"
      >
        Contribute a tip →
      </a>
    </div>

    <p
      data-hero="trust"
      style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.65);margin:16px auto 0;"
    >
      No tracking. No account. Press <kbd
        style="font-family:var(--font-mono);font-size:11px;color:rgba(255,255,255,0.85);border:1px solid rgba(255,255,255,0.25);border-radius:4px;padding:1px 6px;"
        >Esc</kbd
      >, get a blank tab.
    </p>

    <!-- Mini stats strip -->
    <div
      data-hero="stats"
      class="flex flex-wrap items-center justify-center gap-6 mt-10 pt-8"
      style="border-top: 1px solid rgba(255,255,255,0.08);"
    >
      {
        [
          { val: totalTips, label: "tips" },
          { val: totalContribs, label: "contributors" },
          { val: totalStacks, label: "stacks" },
        ].map(({ val, label }) => (
          <div style="display:flex; flex-direction:column; gap:2px; align-items:center;">
            <span
              style="font-family:var(--font-mono);font-size:22px;font-weight:600;color:#ffffff;letter-spacing:-0.5px;font-feature-settings:'tnum';"
              data-count={val}
            >
              {val}
            </span>
            <span style="font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.65); letter-spacing: 0.02em;">
              {label}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import { initStackCycle } from "@/lib/hero-content-client";

  initStackCycle();
</script>
