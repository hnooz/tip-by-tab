---
const { pathname } = Astro.url;
const isHome = pathname === "/";
const contributorsActive = pathname.startsWith("/contributors");
---

<header class="sticky top-0 z-40 bg-canvas/90 backdrop-blur-sm border-b border-hairline">
  <div class="max-w-[1200px] mx-auto px-6 h-14 flex items-center gap-8">
    <a
      href="/"
      class="shrink-0 font-sans text-[17px] font-semibold tracking-[-0.3px] no-underline text-ink"
      aria-label="Daily Dev Tip — home"
    >
      Daily Dev Tip
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="flex-1 hidden sm:flex items-center gap-1">
      <a
        href={isHome ? "#stacks" : "/#stacks"}
        class="px-3 py-1.5 rounded-md text-[14px] font-semibold transition-colors no-underline text-ink-mute hover:text-ink"
      >
        Stacks
      </a>
      <a
        href="/contributors"
        class:list={[
          "px-3 py-1.5 rounded-md text-[14px] font-semibold transition-colors no-underline",
          contributorsActive ? "text-primary bg-primary/7" : "text-ink-mute hover:text-ink",
        ]}
        aria-current={contributorsActive ? "page" : undefined}
      >
        Contributors
      </a>
    </nav>

    <!-- Desktop actions -->
    <div class="hidden sm:flex items-center gap-3 ml-auto">
      <a
        href="https://github.com/hnooz/daily-dev-tips"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost text-[13px]"
        aria-label="GitHub repository"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
        GitHub
      </a>
      <a href="/contribute" class="btn-secondary text-[13px]">Contribute</a>
      <a
        href="https://chrome.google.com/webstore/detail/daily-dev-tip"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-[13px]"
      >
        Install free
      </a>
    </div>

    <!-- Mobile: install + hamburger -->
    <div class="flex sm:hidden items-center gap-2 ml-auto">
      <a
        href="https://chrome.google.com/webstore/detail/daily-dev-tip"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-[12px]"
        style="padding: 7px 14px;"
      >
        Install
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex items-center justify-center w-9 h-9 rounded-md text-ink-mute hover:text-ink hover:bg-canvas-soft transition-colors"
      >
        <svg
          id="icon-open"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          class="hidden"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu panel (below header) -->
<div
  id="mobile-menu"
  class="hidden fixed top-14 left-0 right-0 z-39 bg-canvas border-b border-hairline shadow-2 sm:hidden"
  aria-hidden="true"
>
  <nav class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
    <a
      href={isHome ? "#stacks" : "/#stacks"}
      class="flex items-center px-3 py-3 rounded-md text-[15px] font-semibold text-ink-mute hover:text-ink hover:bg-canvas-soft transition-colors no-underline"
    >
      Stacks
    </a>
    <a
      href="/contributors"
      class:list={[
        "flex items-center px-3 py-3 rounded-md text-[15px] font-semibold transition-colors no-underline",
        contributorsActive
          ? "text-primary bg-primary/7"
          : "text-ink-mute hover:text-ink hover:bg-canvas-soft",
      ]}
    >
      Contributors
    </a>
    <a
      href="/contribute"
      class="flex items-center px-3 py-3 rounded-md text-[15px] font-semibold text-ink-mute hover:text-ink hover:bg-canvas-soft transition-colors no-underline"
    >
      Contribute a tip
    </a>
    <a
      href="https://github.com/hnooz/daily-dev-tips"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center px-3 py-3 rounded-md text-[15px] font-semibold text-ink-mute hover:text-ink hover:bg-canvas-soft transition-colors no-underline"
    >
      GitHub ↗
    </a>
  </nav>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  function openMenu() {
    menu?.classList.remove("hidden");
    menu?.setAttribute("aria-hidden", "false");
    btn?.setAttribute("aria-expanded", "true");
    iconOpen?.classList.add("hidden");
    iconClose?.classList.remove("hidden");
  }

  function closeMenu() {
    menu?.classList.add("hidden");
    menu?.setAttribute("aria-hidden", "true");
    btn?.setAttribute("aria-expanded", "false");
    iconOpen?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
  }

  btn?.addEventListener("click", () => {
    if (menu?.classList.contains("hidden")) openMenu();
    else closeMenu();
  });

  // Close on nav link click
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (
      !menu?.classList.contains("hidden") &&
      !menu?.contains(e.target as Node) &&
      !btn?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  // Close on resize past sm breakpoint
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 640) closeMenu();
  });
</script>
