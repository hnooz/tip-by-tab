---
import StackBadge from "./StackBadge.astro";

interface Props {
  id: string;
  title: string;
  stack: string;
  slug: string;
  tags: string[];
  explanation: string;
  authorName: string;
  authorGithub: string;
  publishedAt: Date | string;
}

const { title, stack, slug, tags, explanation, authorGithub } = Astro.props;

const plain = explanation.replace(/`[^`]+`/g, (m) => m.slice(1, -1));
const excerpt = plain.length > 120 ? plain.slice(0, 119).trimEnd() + "…" : plain;
---

<a href={`/${stack}/${slug}`} class="card-tip">
  <div class="flex items-start justify-between gap-3 mb-[10px]">
    <h3
      class="font-sans text-[15px] font-semibold tracking-[-0.2px] text-ink leading-[1.4] line-clamp-2"
    >
      {title}
    </h3>
    <StackBadge stack={stack} size="sm" />
  </div>

  <p class="text-[13px] font-semibold text-ink-mute leading-[1.55] line-clamp-3 mb-[14px]">
    {excerpt}
  </p>

  <div class="flex items-center justify-between border-t border-hairline pt-[10px]">
    <div class="flex gap-[6px] flex-wrap">
      {
        tags
          .slice(0, 2)
          .map((tag) => (
            <span class="font-mono text-[10px] font-semibold text-ink-mute bg-canvas-soft px-[7px] py-[2px] rounded-full border border-hairline tracking-[0.02em]">
              {tag}
            </span>
          ))
      }
    </div>
    <span class="font-mono text-[11px] font-semibold text-[var(--color-ink-mute-2)]">
      @{authorGithub}
    </span>
  </div>
</a>
