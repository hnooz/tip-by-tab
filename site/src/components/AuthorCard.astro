---
interface Props {
  github: string;
  name: string;
}

const { github, name } = Astro.props;

const initials = name
  .split(" ")
  .map((w) => w[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);
---

<a
  href={`/contributors/${github}`}
  class="flex items-center gap-4 p-5 rounded-lg border border-hairline bg-canvas-soft no-underline shadow-1 transition-[box-shadow,transform] duration-200"
  onmouseenter="this.style.boxShadow='var(--shadow-2)';this.style.transform='translateY(-1px)'"
  onmouseleave="this.style.boxShadow='var(--shadow-1)';this.style.transform='translateY(0)'"
>
  <span
    class="shrink-0 w-[52px] h-[52px] rounded-full bg-primary text-white flex items-center justify-center font-mono text-[16px] font-semibold shadow-[0_4px_12px_rgba(83,58,253,0.25)]"
    aria-hidden="true"
  >
    {initials}
  </span>

  <div class="flex-1 min-w-0">
    <div
      class="text-[10px] font-semibold tracking-[0.12em] uppercase text-ink-mute mb-1 opacity-70"
    >
      Contributed by
    </div>
    <div class="font-mono text-[14px] font-semibold text-ink leading-[1.2]">
      @{github}
    </div>
    <div class="text-[13px] font-semibold text-ink-mute mt-0.5">
      {name}
    </div>
    <div class="flex items-center gap-2 mt-[10px]">
      <div class="h-px flex-1 bg-hairline"></div>
      <span class="text-[12px] text-primary">View profile →</span>
    </div>
  </div>
</a>
