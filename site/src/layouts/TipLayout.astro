---
import BaseLayout from "./BaseLayout.astro";
import InstallCTA from "@/components/InstallCTA.astro";
import TipArticle from "@/components/TipArticle.astro";
import { SITE_NAME, truncate, plainText, ogUrl } from "@/lib/seo";

interface Props {
  title: string;
  stack: string;
  tags: string[];
  language: string;
  file?: string;
  code: string;
  explanation: string;
  authorGithub: string;
  authorName: string;
  publishedAt: Date | string;
  source?: string;
  canonical: string;
  jsonLd: object;
}

const { title, stack, explanation, canonical, jsonLd, ...rest } = Astro.props;

const description = truncate(plainText(explanation), 155);
const ogImage = ogUrl(stack);
---

<BaseLayout
  title={`${title} — ${SITE_NAME}`}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <div id="tip-article" class="max-w-[680px] mx-auto px-6 pt-10 pb-20">
    <!-- Install banner -->
    <div class="mb-9">
      <InstallCTA variant="banner" />
    </div>

    <TipArticle title={title} stack={stack} explanation={explanation} {...rest} />

    <!-- Related tips -->
    {
      Astro.slots.has("related") && (
        <aside class="mt-14 pt-8 border-t border-hairline">
          <h2 class="font-mono text-[11px] font-semibold tracking-[0.12em] uppercase text-ink-mute mb-5">
            More {stack} tips
          </h2>
          <slot name="related" />
        </aside>
      )
    }
  </div>
</BaseLayout>

<script>
  import gsap from "gsap";

  gsap.fromTo(
    "#tip-article",
    { opacity: 0, y: 24 },
    { opacity: 1, y: 0, duration: 0.7, ease: "power3.out" }
  );
</script>
