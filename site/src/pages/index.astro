---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import HowItWorks from "@/components/home/HowItWorks.astro";
import StacksSection from "@/components/home/StacksSection.astro";
import ContributorsSection from "@/components/home/ContributorsSection.astro";
import HomeCTA from "@/components/home/HomeCTA.astro";
import { parseTipBody } from "@/lib/parse-tip";
import { stackLabel } from "@/lib/stacks";
import { SITE_NAME, SITE_DESCRIPTION, SITE_URL } from "@/lib/seo";
import type { HeroTip } from "@/lib/hero-tip-card";

const allTips = await getCollection("tips");
const assigned = allTips.filter((e) => e.data.id);
const sorted = [...assigned].sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// All tips annotated with their stack for client-side filtering
const stackTips = sorted.map((e) => {
  const stack = e.id.split("/")[0];
  const slug = e.id.split("/")[1].replace(".md", "");
  const { explanation } = parseTipBody(e.body ?? "", e.data.language);
  return { entry: e, stack, slug, explanation };
});

const contribMap = new Map<string, { name: string; count: number }>();
for (const e of assigned) {
  const { github, name } = e.data.author;
  contribMap.set(github, { name, count: (contribMap.get(github)?.count ?? 0) + 1 });
}
const founders = [...contribMap.entries()].sort((a, b) => b[1].count - a[1].count).slice(0, 8);

const totalTips = assigned.length;
const totalContribs = contribMap.size;
const totalStacks = [...new Set(assigned.map((e) => e.id.split("/")[0]))].length;

// derive unique stack names for search placeholder
const allStackNames = [...new Set(assigned.map((e) => e.id.split("/")[0]))].sort();
const stackLabels = allStackNames.map(stackLabel);

// Hero demo card: newest tip per stack, up to 6, real content + real authors
const heroTips: HeroTip[] = [];
const heroSeen = new Set<string>();
for (const e of sorted) {
  const stack = e.id.split("/")[0];
  if (heroSeen.has(stack)) continue;
  heroSeen.add(stack);
  const { code, language } = parseTipBody(e.body ?? "", e.data.language);
  if (!code) continue;
  heroTips.push({
    label: stackLabel(stack),
    title: e.data.title,
    code,
    language,
    github: e.data.author.github,
  });
  if (heroTips.length === 6) break;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  publisher: { "@type": "Organization", name: SITE_NAME, url: SITE_URL },
};
---

<BaseLayout
  title={`${SITE_NAME} — One tip per tab`}
  description={SITE_DESCRIPTION}
  canonical={SITE_URL}
  jsonLd={jsonLd}
>
  <HeroSection
    totalTips={totalTips}
    totalContribs={totalContribs}
    totalStacks={totalStacks}
    heroTips={heroTips}
    stackNames={stackLabels}
  />
  <HowItWorks />
  <StacksSection stackTips={stackTips} allStackNames={allStackNames} />
  {founders.length > 0 && <ContributorsSection founders={founders} />}
  <HomeCTA />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  /* ── Scroll reveals — content visible by default, GSAP adds entrance only ── */
  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
      gsap.fromTo(
        el,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 92%", once: true },
        }
      );
    });

    document.querySelectorAll<HTMLElement>("[data-reveal-group]").forEach((group) => {
      gsap.fromTo(
        Array.from(group.children) as HTMLElement[],
        { opacity: 0, y: 28 },
        {
          opacity: 1,
          y: 0,
          duration: 0.65,
          ease: "power3.out",
          stagger: 0.1,
          scrollTrigger: { trigger: group, start: "top 92%", once: true },
        }
      );
    });
  });

  /* ── Card hover depth via GSAP (smoother than CSS) ──────── */
  document
    .querySelectorAll<HTMLElement>(".card-feature, .card-stack, .card-tip")
    .forEach((card) => {
      const anim = gsap.to(card, {
        y: -4,
        boxShadow: "0 14px 36px rgba(0,55,112,0.1), 0 4px 12px rgba(0,55,112,0.06)",
        duration: 0.25,
        ease: "power2.out",
        paused: true,
      });
      card.addEventListener("mouseenter", () => anim.play());
      card.addEventListener("mouseleave", () => anim.reverse());
    });
</script>
